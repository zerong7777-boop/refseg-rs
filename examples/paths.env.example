# RefSeg local path template.
# Replace the placeholder values with local paths before sourcing.

export REFSEG_PROJECT_ROOT="/absolute/path/to/refseg-rs"
export REFSEG_CHECKPOINT_ROOT="${REFSEG_PROJECT_ROOT}/checkpoints"

export REFSEG_REFER_DATA_ROOT="/absolute/path/to/refer_data_root"
export REFSEG_RSREFSEGRS_DATA_ROOT="/absolute/path/to/rsrefsegrs_data_root"

# Default runtime device. Use cpu or a CUDA device such as cuda:0.
export REFSEG_DEVICE="cuda:0"

# Optional: leave empty unless you need to point at a separate site-packages tree.
# If set, use a single path such as /path/to/python3.10/site-packages.
export REFSEG_RUNTIME_SITE_PACKAGES=""

# Keep user-site packages out of the runtime.
export PYTHONNOUSERSITE="1"
